rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    // True when the request comes from an authenticated Firebase user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the role string stored in the caller's users/{uid} document.
    // NOTE: each call costs one Firestore read from the security-rules quota.
    // Only evaluated on write paths or admin-read paths; public reads bypass it.
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // True when the authenticated caller has the 'admin' role.
    function isAdmin() {
      return isSignedIn() && callerRole() == 'admin';
    }

    // True when the authenticated caller's UID matches the given uid argument.
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }


    // =========================================================================
    // PUBLIC CONTENT  — no auth required
    // These collections hold non-sensitive business data needed by the public
    // homepage (session map, gallery) and the portal find-class page.
    // =========================================================================

    // Gallery images shown on the public /gallery page.
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Session instances — public read needed by the unauthenticated homepage map
    // and the portal session browser.
    //
    // CHANGED (webhook refactor): the narrow "authenticated user may decrement
    // spotsAvailable" rule has been REMOVED. Capacity is now decremented
    // exclusively by the Stripe webhook handler using Firebase Admin SDK, which
    // bypasses these rules entirely.
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Venues — shown on maps (public homepage) and in admin management.
    match /venues/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Class definitions — read by admin session creation form.
    // Made public for simplicity; contains no PII.
    match /classes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Recipes — used in admin session creation and session detail display.
    match /recipes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Instructors — public bio/photo display (About page future).
    match /instructors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // =========================================================================
    // CONTACT MESSAGES  — server-side writes only (Admin SDK bypasses rules)
    // =========================================================================
    //
    // contact_messages/{docId} are created by the /api/contact route handler
    // (server-side, Admin SDK). No client should ever create or delete them.
    // Admins read/update status via the client SDK (admin inbox page).
    match /contact_messages/{docId} {
      allow create, delete: if false;
      allow read, update: if isAdmin();
    }


    // =========================================================================
    // BOOKING DRAFTS  — server-side only (Admin SDK bypasses these rules)
    // =========================================================================
    //
    // booking_drafts/{paymentIntentId} documents are written by the
    // create-intent API route (server-side, Admin SDK) and read/deleted by
    // the Stripe webhook handler (server-side, Admin SDK).
    //
    // No client should ever read or write this collection directly.
    // The deny-all rule makes this explicit and prevents accidental exposure.
    match /booking_drafts/{docId} {
      allow read, write: if false;
    }


    // =========================================================================
    // USERS
    // =========================================================================

    match /users/{uid} {
      // Read: own profile (AuthContext on every login) or admin dashboard.
      allow read: if isOwner(uid) || isAdmin();

      // Create: user creates their own profile at sign-up.
      //   - document uid must match the authenticated uid (prevents spoofing)
      //   - role must be a non-admin role; 'admin' accounts can only be created
      //     server-side via the Firebase Admin SDK or Firebase Console
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['parent', 'youngAdult'];

      // Update: owner may only change safe display fields.
      //   - affectedKeys check ensures no other field can be touched in one call
      //   - explicit equality guards defend against full-document overwrites
      //     (setDoc without merge) that carry unchanged privileged values
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['firstName', 'lastName', 'phone', 'updatedAt'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid  == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
    }


    // =========================================================================
    // STUDENTS
    // =========================================================================

    match /students/{studentId} {
      // Read: own parent (query uses where('parentUid', '==', user.uid)) or admin.
      // Firestore validates the query constraint matches the rule, so collection
      // scans are safe for the parentUid == uid pattern.
      allow read: if isOwner(resource.data.parentUid) || isAdmin();

      // Create: parent sets themselves as owner; only expected fields allowed.
      // medicalInfo/emergencyContact/questionnaire are written exclusively by the
      // Stripe webhook (Admin SDK) — no client should set them at creation time.
      allow create: if isSignedIn()
        && request.resource.data.parentUid == request.auth.uid
        && request.resource.data.keys().hasOnly(
             ['firstName', 'lastName', 'dateOfBirth', 'parentUid', 'createdAt']);

      // Update: owner may only change display fields; parentUid and createdAt
      // are immutable. medicalInfo/emergencyContact/questionnaire are owned by
      // the webhook — the affectedKeys guard blocks any client-side write to them.
      allow update: if isSignedIn()
        && resource.data.parentUid == request.auth.uid
        && request.resource.data.parentUid == resource.data.parentUid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['firstName', 'lastName', 'dateOfBirth', 'updatedAt']);

      // Delete: owner only.
      allow delete: if isSignedIn()
        && resource.data.parentUid == request.auth.uid;
    }


    // =========================================================================
    // BOOKINGS
    // =========================================================================
    //
    // CHANGED (webhook refactor): client-side booking creation has been
    // REMOVED. Bookings are now created exclusively by the Stripe webhook
    // handler (/api/webhooks/stripe) using Firebase Admin SDK.
    //
    // The 'allow create' rule is intentionally absent. Any attempt to create
    // a booking from the browser will be denied.
    // =========================================================================

    match /bookings/{bookingId} {
      // A user may read their own bookings.
      // (my-classes, my-payments, and confirmation page all use this path.)
      allow read: if isSignedIn()
        && resource.data.bookedByUid == request.auth.uid;

      // A user may cancel their own booking.
      // my-classes/page.tsx sends: { status: 'cancelled', cancelledAt: new Date() }
      // Only those two fields may change; no other fields can be modified.
      allow update: if isSignedIn()
        && resource.data.bookedByUid == request.auth.uid
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'cancelledAt']);

      // Admins: full access.
      allow read, write: if isAdmin();
    }

  }
}
